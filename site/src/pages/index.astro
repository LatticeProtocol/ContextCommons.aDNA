---
import PageLayout from '../layouts/PageLayout.astro';
import RoleCard from '../components/sections/RoleCard.astro';
import CTABanner from '../components/sections/CTABanner.astro';
import ThreeRoleLoop from '../components/diagrams/ThreeRoleLoop.astro';
import IconHammer from '../components/icons/IconHammer.astro';
import IconShield from '../components/icons/IconShield.astro';
import IconBook from '../components/icons/IconBook.astro';
import PilotCard from '../components/sections/PilotCard.astro';
---

<PageLayout
  title="Home"
  description="Context Commons — An intergenerational program where youth build AI tools, elders share wisdom, and communities own what they need."
  fullWidth={true}
  jsonLD={{
    '@context': 'https://schema.org',
    '@type': 'Organization',
    name: 'Context Commons',
    description: 'An intergenerational program where youth build AI tools, elders share wisdom, and communities own what they need.',
    url: 'https://contextcommons.org',
    foundingDate: '2026',
    areaServed: ['Grand Rapids, MI', 'Los Angeles, CA'],
  }}
>
  <!-- Hero -->
  <section class="bg-[var(--color-bg-alt)]">
    <!-- Inline hero image -->
    <div class="max-w-[80%] md:max-w-[42%] mx-auto pt-[var(--space-6)]">
      <picture>
        <source srcset="/images/hero/hero_community_480.webp" media="(max-width: 480px)" type="image/webp" />
        <source srcset="/images/hero/hero_community_768.webp" media="(max-width: 768px)" type="image/webp" />
        <source srcset="/images/hero/hero_community_1268.webp" type="image/webp" />
        <img
          src="/images/hero/hero_community_1268.jpg"
          alt="Pixel art illustration of an intergenerational community: young people, elders, and mentors working together at computers in a warm community center beneath a wooden Context Commons sign"
          class="w-full h-auto rounded-[var(--radius-lg)]"
          loading="eager"
          fetchpriority="high"
          decoding="async"
        />
      </picture>
    </div>
    <!-- Tagline below image -->
    <div class="py-[var(--space-12)] md:py-[var(--space-16)] px-[var(--space-4)] text-center max-w-[var(--prose-width-wide)] mx-auto">
      <h1 class="font-display text-[length:var(--text-5xl)] text-[var(--color-text)] mb-[var(--space-4)] leading-[1.1]">
        Every community deserves its own printing press.
      </h1>
      <p class="text-[length:var(--text-2xl)] text-[var(--color-text-muted)] mb-[var(--space-8)] max-w-[var(--prose-width)] mx-auto leading-snug">
        An intergenerational program: youth build AI tools, elders share the wisdom that makes them work, communities own what they need.
      </p>
      <a
        href="/get-involved"
        class="inline-block px-[var(--space-8)] py-[var(--space-4)] bg-[var(--brand-accent)] font-semibold rounded-[var(--radius-md)] text-[length:var(--text-lg)] hover:bg-[var(--brand-accent-light)] shadow-[var(--shadow-lg)] hover:shadow-[0_12px_24px_hsl(0_0%_0%/0.2)] transition-all duration-[var(--transition-base)]"
        style="color: var(--brand-primary-dark);"
      >
        Join the Commons
      </a>
    </div>
  </section>

  <!-- The Problem -->
  <section class="py-[var(--space-12)] px-[var(--space-4)]">
    <div class="max-w-[var(--prose-width)] mx-auto text-center">
      <h2 class="font-display text-[length:var(--text-3xl)] text-[var(--color-text)] mb-[var(--space-4)]" data-animate>
        One problem. One solution.
      </h2>
      <p class="text-[length:var(--text-lg)] text-[var(--color-text-muted)] mb-[var(--space-4)] leading-relaxed">
        AI is reshaping how people work &mdash; but the communities that need it most have the least access. Meanwhile, young people in those communities are ready to build, if someone shows them how.
      </p>
      <p class="text-[length:var(--text-xl)] text-[var(--color-text)] font-semibold mb-[var(--space-4)]">
        Context Commons closes both gaps: youth learn to build, elders teach what matters, the community owns what they make.
      </p>
      <a
        href="/about"
        class="inline-block text-[length:var(--text-base)] font-semibold text-[var(--brand-primary-dark)] hover:underline focus-visible:underline"
      >
        Read the full thesis &rarr;
      </a>
    </div>
  </section>

  <!-- Three Roles -->
  <section class="py-[var(--space-12)] md:py-[var(--space-16)] px-[var(--space-4)] bg-[var(--color-bg-alt)]">
    <div class="max-w-[var(--content-width)] mx-auto">
      <h2 class="font-display text-[length:var(--text-3xl)] text-[var(--color-text)] text-center mb-[var(--space-3)]" data-animate>
        Three roles, one loop
      </h2>
      <p class="text-[length:var(--text-lg)] text-[var(--color-text-muted)] text-center max-w-[var(--prose-width)] mx-auto mb-[var(--space-8)]">
        Knowledge flows in every direction. Everyone contributes. Everyone benefits.
      </p>
      <ThreeRoleLoop class="mb-[var(--space-8)]" />
      <div class="grid grid-cols-1 md:grid-cols-3 gap-[var(--space-6)]" data-animate>
        <RoleCard
          title="Youth Builders"
          who="Ages 14&ndash;24"
          description="Learn to build AI tools that help real neighbors. Graduate with a working project and your own computer."
        >
          <IconHammer slot="icon" />
        </RoleCard>
        <RoleCard
          title="Community Stewards"
          who="Pastors, teachers, organizers"
          description="Learn how the tools work so you decide how they're used here. If a tool doesn't serve your people, it doesn't ship."
        >
          <IconShield slot="icon" />
        </RoleCard>
        <RoleCard
          title="Elders &amp; Community"
          who="Beneficiaries and co-designers"
          description="Share what no computer can guess. Help decide what gets built. Say whether it actually works."
        >
          <IconBook slot="icon" />
        </RoleCard>
      </div>
      <p class="text-center mt-[var(--space-8)]">
        <a
          href="/get-involved"
          class="inline-block text-[length:var(--text-lg)] font-semibold text-[var(--brand-primary-dark)] hover:underline focus-visible:underline"
        >
          See all the ways to take part &rarr;
        </a>
      </p>
    </div>
  </section>

  <!-- Where we're working -->
  <section class="py-[var(--space-12)] md:py-[var(--space-16)] px-[var(--space-4)]">
    <div class="max-w-[var(--content-width)] mx-auto">
      <h2 class="font-display text-[length:var(--text-3xl)] text-[var(--color-text)] text-center mb-[var(--space-3)]" data-animate>
        Where we're working
      </h2>
      <p class="text-[length:var(--text-lg)] text-[var(--color-text-muted)] text-center max-w-[var(--prose-width)] mx-auto mb-[var(--space-8)]">
        Two pilots launch in 2026. Real neighbors. Real tools. No toy problems.
      </p>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-[var(--space-6)] md:gap-[var(--space-8)]">
        <PilotCard
          label="Pilot A &middot; Q3 2026"
          title="Grand Rapids, MI"
          description="8&ndash;12 youth builders at Peter's Church build AI tools for 20+ elders &mdash; Medicare navigation, care coordination &mdash; in English, Swahili, Karen, and Arabic."
          href="/pilots"
          outcome="Testing depth &mdash; one community, one shared knowledge system."
        />
        <PilotCard
          label="Pilot B &middot; Q4 2026"
          title="Los Angeles, CA"
          description="LAUSD, Venice Beach Book Club, UCLA. 12&ndash;16 builders. 100+ languages. Immigration paperwork, school enrollment, family services."
          href="/pilots"
          outcome="Testing breadth &mdash; can community-governed AI work across languages and institutions?"
        />
      </div>
      <p class="text-center mt-[var(--space-8)]">
        <a
          href="/pilots"
          class="inline-block text-[length:var(--text-lg)] font-semibold text-[var(--brand-primary-dark)] hover:underline focus-visible:underline"
        >
          See what youth will build &rarr;
        </a>
      </p>
    </div>
  </section>

  <!-- CTA -->
  <CTABanner
    heading="There's a place for you in the commons."
    description="Whether you're a young person who wants to build, a community leader, a developer who wants to mentor, or a funder who wants to invest in community-owned technology &mdash; we'd like to hear from you."
    ctaText="Get Involved"
    ctaHref="/get-involved"
    variant="accent"
  />
</PageLayout>
