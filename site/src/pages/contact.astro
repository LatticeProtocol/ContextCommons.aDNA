---
import PageLayout from '../layouts/PageLayout.astro';
---

<PageLayout
  title="Contact"
  description="Tell us about your community. We'd love to hear from you — communities, mentors, and partners welcome."
>
  <section class="py-[var(--space-16)]">
    <h1 class="text-[var(--text-3xl)] mb-[var(--space-6)]">Contact</h1>
    <p class="text-[var(--text-lg)] text-[var(--color-text-muted)] max-w-[var(--prose-width)]">
      Content will be generated in M08 with application forms for communities, mentors, and partners.
    </p>
  </section>
</PageLayout>
