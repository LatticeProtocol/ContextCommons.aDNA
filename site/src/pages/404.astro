---
import PageLayout from '../layouts/PageLayout.astro';
---

<PageLayout title="Page Not Found" description="The page you're looking for doesn't exist.">
  <section class="py-[var(--space-32)] text-center">
    <h1 class="text-[var(--text-4xl)] mb-[var(--space-4)]">404</h1>
    <p class="text-[var(--text-lg)] text-[var(--color-text-muted)] mb-[var(--space-8)]">
      This page doesn't exist yet. The commons is still being built.
    </p>
    <a href="/" class="inline-block px-[var(--space-6)] py-[var(--space-3)] bg-[var(--brand-primary)] text-white font-semibold rounded-[var(--radius-md)] hover:opacity-90 transition-opacity">
      Back to Home
    </a>
  </section>
</PageLayout>
