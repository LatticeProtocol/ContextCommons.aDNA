>
  <section class="py-[var(--space-16)]">
    <h1 class="text-[var(--text-3xl)] mb-[var(--space-6)]">Resources</h1>
    <p class="text-[var(--text-lg)] text-[var(--color-text-muted)] max-w-[var(--prose-width)]">
      Content will be generated in M08 using the aDNA for communities context.
    </p>
  </section>
</PageLayout>
