---
import PageLayout from '../layouts/PageLayout.astro';
---

<PageLayout
  title="Get Involved"
  description="There's a place for you in the Context Commons. Whether you build, govern, guide, or teach — start here."
>
  <section class="py-[var(--space-16)]">
    <h1 class="text-[var(--text-3xl)] mb-[var(--space-6)]">Get Involved</h1>
    <p class="text-[var(--text-lg)] text-[var(--color-text-muted)] max-w-[var(--prose-width)]">
      Content will be generated in M08 using the community engagement context.
    </p>
  </section>
</PageLayout>
