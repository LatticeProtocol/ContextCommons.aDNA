---
interface Props {
  label: string;
  variant?: 'default' | 'draft';
}

const { label, variant = 'default' } = Astro.props;
const isDraft = variant === 'draft';
---

<span
  class:list={[
    'inline-flex items-center px-[var(--space-2)] py-[2px] border text-[length:var(--text-xs)] uppercase tracking-[0.08em]',
    isDraft
      ? 'border-[var(--press-red)] text-[var(--press-red)]'
      : 'border-[var(--ink)] text-[var(--ink-soft)]',
  ]}
  style="font-family: var(--font-mono);"
  aria-label={isDraft ? 'Draft status' : undefined}
>
  {label.toUpperCase()}
</span>
