---
interface Props {
  id: string;
  title: string;
  accentColor?: string;
}

const { id, title, accentColor } = Astro.props;
const borderStyle = accentColor ? `border-top-color: ${accentColor}` : 'border-top-color: var(--brand-primary)';
---

<details
  id={id}
  class="group border border-[var(--color-border)] border-t-2 rounded-[var(--radius-lg)] bg-[var(--color-surface)] shadow-[var(--shadow-sm)] hover:shadow-[var(--shadow-md)] open:shadow-[var(--shadow-md)] transition-shadow duration-[var(--transition-base)] scroll-mt-[var(--space-16)]"
  style={borderStyle}
>
  <summary class="cursor-pointer list-none p-[var(--space-6)] md:p-[var(--space-8)] flex items-center justify-between gap-[var(--space-4)] [&::-webkit-details-marker]:hidden">
    <h2 class="font-display text-[length:var(--text-2xl)] text-[var(--color-text)]">{title}</h2>
    <svg class="w-5 h-5 shrink-0 text-[var(--color-text-muted)] transition-transform duration-[var(--transition-base)] group-open:rotate-180" aria-hidden="true" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" /></svg>
  </summary>
  <div class="px-[var(--space-6)] md:px-[var(--space-8)] pb-[var(--space-6)] md:pb-[var(--space-8)]">
    <slot />
  </div>
</details>
