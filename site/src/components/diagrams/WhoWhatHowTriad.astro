---
interface Props { class?: string; }
const { class: className } = Astro.props;

const pillars = [
  { label: 'WHO', sub: 'People', cx: 90 },
  { label: 'WHAT', sub: 'Knowledge', cx: 250 },
  { label: 'HOW', sub: 'Processes', cx: 410 },
];
---

<div class:list={["diagram-wrapper", className]}>
  <svg
    role="img"
    aria-label="Context graph structure: WHO (People), WHAT (Knowledge), and HOW (Processes) are three interconnected pillars"
    viewBox="0 0 500 130"
    fill="none"
    xmlns="http://www.w3.org/2000/svg"
    class="w-full h-auto max-w-xl mx-auto"
  >
    <defs>
      <marker id="triad-arrow" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="5" markerHeight="5" orient="auto-start-reverse">
        <path d="M 0 0 L 10 5 L 0 10 z" fill="var(--brand-primary)" />
      </marker>
    </defs>

    {/* Connecting lines between pillars */}
    <line x1={145} y1={50} x2={195} y2={50} stroke="var(--brand-primary)" stroke-width="2" marker-end="url(#triad-arrow)" />
    <line x1={195} y1={60} x2={145} y2={60} stroke="var(--brand-primary)" stroke-width="2" marker-end="url(#triad-arrow)" />
    <line x1={305} y1={50} x2={355} y2={50} stroke="var(--brand-primary)" stroke-width="2" marker-end="url(#triad-arrow)" />
    <line x1={355} y1={60} x2={305} y2={60} stroke="var(--brand-primary)" stroke-width="2" marker-end="url(#triad-arrow)" />

    {/* Curved line WHO <-> HOW (under) */}
    <path d="M 90 80 Q 250 160 410 80" stroke="var(--brand-primary)" stroke-width="1.5" stroke-dasharray="6 4" fill="none" />

    {/* Pillar nodes */}
    {pillars.map((p) => (
      <g>
        <rect x={p.cx - 50} y={25} width={100} height={60} rx="10" fill="var(--color-surface)" stroke="var(--brand-primary)" stroke-width="2" />
        <text x={p.cx} y={50} text-anchor="middle" fill="var(--brand-primary)" font-size="16" font-weight="700">{p.label}</text>
        <text x={p.cx} y={70} text-anchor="middle" fill="var(--color-text-muted)" font-size="12">{p.sub}</text>
      </g>
    ))}

    {/* Central label */}
    <text x={250} y={125} text-anchor="middle" fill="var(--color-text-muted)" font-size="11" font-style="italic">Your community's context graph</text>
  </svg>
</div>
