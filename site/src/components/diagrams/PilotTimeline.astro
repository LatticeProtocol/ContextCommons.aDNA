---
interface Props { class?: string; }
const { class: className } = Astro.props;

const pilots = [
  { name: 'Grand Rapids', quarters: ['Q2 2026', 'Q3 2026', 'Q4 2026'], activeIndex: 1 },
  { name: 'Los Angeles', quarters: ['Q3 2026', 'Q4 2026', 'Q1 2027'], activeIndex: 1 },
];
const phases = ['Pre-launch', 'Active pilot', 'Post-pilot'];
const segW = 130;
const gap = 4;
const labelX = 100;
const startX = labelX + 10;
---

<div class:list={["diagram-wrapper", className]}>
  <svg
    role="img"
    aria-label="Pilot timeline: Grand Rapids active Q3 2026, Los Angeles active Q4 2026"
    viewBox="0 0 510 170"
    fill="none"
    xmlns="http://www.w3.org/2000/svg"
    class="w-full h-auto max-w-2xl mx-auto"
  >
    {pilots.map((pilot, row) => {
      const y = 20 + row * 80;
      return (
        <g>
          {/* Pilot label */}
          <text x={labelX} y={y + 16} text-anchor="end" fill="var(--color-text)" font-size="14" font-weight="600">
            {pilot.name}
          </text>
          {/* Phase segments */}
          {phases.map((_, i) => {
            const x = startX + i * (segW + gap);
            const isActive = i === pilot.activeIndex;
            return (
              <rect
                x={x}
                y={y}
                width={segW}
                height={24}
                rx="12"
                fill={isActive ? 'var(--brand-primary)' : 'var(--color-border)'}
              />
            );
          })}
          {/* Quarter labels */}
          {pilot.quarters.map((q, i) => {
            const x = startX + i * (segW + gap) + segW / 2;
            const isActive = i === pilot.activeIndex;
            return (
              <text
                x={x}
                y={y + 48}
                text-anchor="middle"
                fill={isActive ? 'var(--brand-primary)' : 'var(--color-text-muted)'}
                font-size="11"
                font-weight={isActive ? '600' : '400'}
              >
                {q}
              </text>
            );
          })}
          {/* Phase labels (only on first row) */}
          {row === 0 && phases.map((phase, i) => {
            const x = startX + i * (segW + gap) + segW / 2;
            return (
              <text x={x} y={y + 62} text-anchor="middle" fill="var(--color-text-muted)" font-size="10">
                {phase}
              </text>
            );
          })}
        </g>
      );
    })}
  </svg>
</div>
