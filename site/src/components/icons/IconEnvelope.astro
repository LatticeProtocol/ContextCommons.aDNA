---
interface Props {
  class?: string;
}

const { class: className } = Astro.props;
---

<svg
  xmlns="http://www.w3.org/2000/svg"
  viewBox="0 0 24 24"
  fill="none"
  stroke="currentColor"
  stroke-width="1.5"
  stroke-linecap="round"
  stroke-linejoin="round"
  class:list={["w-8 h-8", className]}
  aria-hidden="true"
>
  <!-- Envelope body -->
  <rect x="2" y="4" width="20" height="16" rx="2" />
  <!-- Flap -->
  <polyline points="2,4 12,13 22,4" />
</svg>
