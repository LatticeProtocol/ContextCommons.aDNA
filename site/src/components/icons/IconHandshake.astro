---
interface Props {
  class?: string;
}

const { class: className } = Astro.props;
---

<svg
  xmlns="http://www.w3.org/2000/svg"
  viewBox="0 0 24 24"
  fill="none"
  stroke="currentColor"
  stroke-width="1.5"
  stroke-linecap="round"
  stroke-linejoin="round"
  class:list={["w-8 h-8", className]}
  aria-hidden="true"
>
  <!-- Two hands meeting -->
  <path d="M2 14l4-4 3 1 4-4 3 3-3 3 1 3 4-4" />
  <path d="M22 14l-4-4-3 1" />
  <!-- Wrists -->
  <path d="M2 14l1 4h4l1-1" />
  <path d="M22 14l-1 4h-4l-1-1" />
</svg>
