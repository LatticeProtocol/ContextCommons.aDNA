---
interface Props {
  class?: string;
}

const { class: className } = Astro.props;
---

<svg
  xmlns="http://www.w3.org/2000/svg"
  viewBox="0 0 24 24"
  fill="none"
  stroke="currentColor"
  stroke-width="1.5"
  stroke-linecap="round"
  stroke-linejoin="round"
  class:list={["w-8 h-8", className]}
  aria-hidden="true"
>
  <!-- Three books standing upright -->
  <rect x="3" y="4" width="4" height="16" rx="0.5" />
  <rect x="9" y="2" width="4" height="18" rx="0.5" />
  <rect x="15" y="5" width="4" height="15" rx="0.5" />
  <!-- Spine details -->
  <line x1="5" y1="8" x2="5" y2="8.01" />
  <line x1="11" y1="6" x2="11" y2="6.01" />
  <line x1="17" y1="9" x2="17" y2="9.01" />
</svg>
