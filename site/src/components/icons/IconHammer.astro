---
interface Props {
  class?: string;
}

const { class: className } = Astro.props;
---

<svg
  xmlns="http://www.w3.org/2000/svg"
  viewBox="0 0 24 24"
  fill="none"
  stroke="currentColor"
  stroke-width="1.5"
  stroke-linecap="round"
  stroke-linejoin="round"
  class:list={["w-8 h-8", className]}
  aria-hidden="true"
>
  <!-- Hammer head -->
  <path d="M6 6l4-4 8 8-4 4z" />
  <!-- Handle -->
  <path d="M10 10L3 21" />
  <!-- Head detail -->
  <path d="M14 2l4 4" />
</svg>
